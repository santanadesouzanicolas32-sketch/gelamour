{
  "compilerOptions": {
    "target": "ES2017",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2017", "DOM", "DOM.Iterable"],
    "rootDir": "src",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": false,
    "paths": {
      "@core/*": ["./core/*"],
      "@domain/*": ["./domain/*"],
      "@app/*": ["./application/*"],
      "@infra/*": ["./infrastructure/*"],
      "@types/*": ["./types/*"],
      "@utils/*": ["./utils/*"],
      "@state/*": ["./state/*"],
      "@modules/*": ["./modules/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build.js"]
}
